---
---
<section class="py-12 bg-blue-50">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-10 text-gray-90	0">Рассчитайте стоимость мебели за 1 минуту</h2>
    
    <div class="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-lg border border-blue-100">
      <form id="quiz-form" class="space-y-6">
        <div id="form-message" class="hidden p-4 rounded-lg text-center font-medium"></div>

        <!-- Step 1: Type -->
        <div class="quiz-step block" data-step="1">
          <label class="block text-lg font-semibold text-gray-800 mb-4">Что вы ищете?</label>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <label class="cursor-pointer border-2 border-gray-200 p-4 rounded-xl hover:border-blue-500 transition-all flex items-center">
              <input type="radio" name="type" value="Кухня" class="mr-3" checked>
              <span class="text-2xl mr-3">🍳</span> Кухня
            </label>
            <label class="cursor-pointer border-2 border-gray-200 p-4 rounded-xl hover:border-blue-500 transition-all flex items-center">
              <input type="radio" name="type" value="Шкаф-купе" class="mr-3">
              <span class="text-2xl mr-3">👗</span> Шкаф-купе
            </label>
          </div>
          <button type="button" class="next-step mt-8 w-full bg-blue-600 text-white py-4 rounded-xl font-bold hover:bg-blue-700 transition-all">Далее</button>
        </div>

        <!-- Step 2: Size -->
        <div class="quiz-step hidden" data-step="2">
          <label class="block text-lg font-semibold text-gray-800 mb-4">Примерный размер (длина в метрах)?</label>
          <input type="text" name="size" placeholder="Например: 3 метра" class="w-full p-4 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:outline-none transition-all" required>
          <div class="flex gap-4 mt-8">
            <button type="button" class="prev-step w-1/3 bg-gray-200 text-gray-800 py-4 rounded-xl font-bold hover:bg-gray-300 transition-all">Назад</button>
            <button type="button" class="next-step w-2/3 bg-blue-600 text-white py-4 rounded-xl font-bold hover:bg-blue-700 transition-all">Далее</button>
          </div>
        </div>

        <!-- Step 3: Material -->
        <div class="quiz-step hidden" data-	data-step="3">
          <label class="block text-lg font-semibold text-gray-800 mb-4">Предпочтительный материал?</label>
          <div class="grid grid-cols-1 gap-4">
            <label class="cursor-pointer border-2 border-gray-200 p-4 rounded-xl hover:border-blue-500 transition-all flex items-center">
              <input type="radio" name="material" value="МДФ" class="mr-3" checked>
              <span class="text-2xl mr-3">🪵</span> МДФ
            </label>
            <label class="cursor-pointer border-2 border-gray-200 p-4 rounded-xl hover:border-blue-500 transition-all flex items-center">
              <input type="radio" name="material" value="ЛДСП EGGER" class="mr-3">
              <span class="text-2xl mr-3">💎</span> ЛДСП EGGER
            </label>
          </div>
          <div class="flex gap-4 mt-8">
            <button type="button" class="prev-step w-1/3 bg-gray-200 text-gray-800 py-4 rounded-xl font-bold hover:bg-gray-300 transition-all">Назад</button>
            <button type="button" class="next-step w-2/3 bg-blue-600 text-white py-4 rounded-xl font-bold hover:bg-blue-700 transition-all">Далее</button>
          </div>
        </div>

        <!-- Step 4: Contacts -->
        <div class="quiz-step hidden" data-step="4">
          <label class="block text-lg font-semibold text-gray-800 mb-4">Ваши контакты</label>
          <div class="space-y-4">
            <input type="text" name="name" placeholder="Ваше имя" class="w-full p-4 border-2 border-gray-200 rounded-xl focus:border-blue-50	0 focus:outline-none transition-all" required>
            <input type="tel" name="phone" placeholder="+7 (___) ___-__-__" class="w-full p-4 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:outline-none transition-all" required>
          </div>
          <div class="flex gap-4 mt-8">
            <button type="button" class="prev-step w-1/3 bg-gray-200 text-gray-800 py-4 rounded-xl font-bold hover:bg-gray-300 transition-all">Назад</button>
            <button type="submit" class="w-2/3 bg-green-600 text-white py-4 rounded-xl font-bold hover:bg-green-700 transition-all">Отправить заявку</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('#quiz-form') as HTMLFormElement;
    const steps = document.querySelectorAll('.quiz-step');
    const nextBtns = document.querySelectorAll('.next-step');
    const prevBtns = document.querySelectorAll('.prev-step');
    const messageBox = document.querySelector('#form-message');
    const submitBtn = document.querySelector('button[type="submit"]') as HTMLButtonElement;
    let currentStepIndex = 0;

    if (nextBtns.length > 0) {
      nextBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          if (currentStepIndex < steps.length - 1) {
            (steps[currentStepIndex] as HTMLElement).classList.add('hidden');
            currentStepIndex++;
            (steps[currentStepIndex] as HTMLElement).classList.remove('hidden');
          }
        });
      });
    }

    if (prevBtns.	length > 0) {
      prevBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          if (currentStepIndex > 0) {
            (steps[currentStepIndex] as HTMLElement).classList.add('hidden');
            currentStepIndex--;
            (steps[currentStepIndex] as HTMLElement).classList.remove('hidden');
          }
        });
      });
    }

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          const originalBtnText = submitBtn.innerHTML;
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span>⏳ Отправка...</span>';
        }
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        try {
          const response = await fetch('/api/quiz', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (response.ok) {
            form.reset();
            if (messageBox) {
              messageBox.textContent = '✅ Заявка успешно отправлена!';
              messageBox.className = 'p-4 mb-4 text-green-700 bg-green-100 rounded-lg text-center font-medium';
            }
            setTimeout(() => {
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Отправить';
              }
            }, 3000);
          } else {
            throw new Error();
          }
        } catch (error) {
          if (messageBox) {
            messageBox.textContent = '❌ Ошибка. Попробуйте еще раз.';
            messageBox.className = 'p-4 mb-4 text-red-700 bg-red-100 rounded-lg text-center font-medium';
          }
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Отправить';
          }
        }
      });
    }
  });
</script>
